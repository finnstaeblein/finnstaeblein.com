---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('lattice', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const themeLabels: Record<string, string> = {
  tech: 'Tech',
  strategy: 'Strategy',
  gtm: 'GTM',
  epistemics: 'Epistemics',
};

// Resolve related slugs to published entries only (skip drafts / unknowns).
const published = await getCollection('lattice', ({ data }) => !data.draft);
const titleById = new Map(published.map(e => [e.id, e.data.title]));
const related = (entry.data.related ?? []).filter((id: string) => titleById.has(id));

const dateStr = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<PageLayout title={`${entry.data.title} — Finn Stäblein`} description={entry.data.summary}>
  <article class="lattice-detail">
    <a href="/lattice" class="back-link">&larr; Lattice</a>

    <header class="lattice-detail-header">
      <div class="meta-block">
        <div class="meta-row">
          <span class="meta-label mono">Theme</span>
          <span>{themeLabels[entry.data.theme] ?? entry.data.theme}</span>
        </div>
        {entry.data.source && (
          <div class="meta-row">
            <span class="meta-label mono">Source</span>
            <span>{entry.data.source}</span>
          </div>
        )}
        <div class="meta-row">
          <span class="meta-label mono">Added</span>
          <time datetime={entry.data.date.toISOString()}>{dateStr}</time>
        </div>
        {entry.data.tags.length > 0 && (
          <div class="meta-row">
            <span class="meta-label mono">Tags</span>
            <span>{entry.data.tags.join(', ')}</span>
          </div>
        )}
        {related.length > 0 && (
          <div class="meta-row">
            <span class="meta-label mono">Related</span>
            <span class="related-links">
              {related.map((id: string, i: number) => (
                <>
                  <a href={`/lattice/${id}`} class="ext-link">{titleById.get(id)}</a>{i < related.length - 1 ? ', ' : ''}
                </>
              ))}
            </span>
          </div>
        )}
      </div>

      <h1>{entry.data.title}</h1>
      <p class="lattice-summary">{entry.data.summary}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>

<style>
  .lattice-detail {
    max-width: var(--content-width);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .lattice-detail-header {
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .meta-block {
    border: 1px solid var(--color-border);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-4);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-bg);
  }

  .meta-row:last-child {
    border-bottom: none;
  }

  .meta-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
    align-self: baseline;
  }

  .ext-link {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .ext-link:hover {
    color: var(--color-accent);
  }

  .lattice-detail-header h1 {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .lattice-summary {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
  }
</style>
