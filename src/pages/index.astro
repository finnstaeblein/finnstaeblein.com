---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Finn Stäblein">
  <main class="home">
    <div class="home-content">
      <h1 class="home-name" transition:name="site-name">Finn<br />Stäblein</h1>
      <nav class="home-nav">
        <a href="/about" class="home-link">About</a>
        <a href="/notes" class="home-link">Index</a>
        <a href="/projects" class="home-link">Projects</a>
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
    padding: var(--space-8) var(--space-6);
    display: flex;
    align-items: flex-start;
  }

  .home-content {
    padding-top: 20vh;
  }

  .home-name {
    font-size: clamp(2.5rem, 10vw, var(--text-4xl));
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-8);
  }

  .home-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .home-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition:
      color var(--duration-base) var(--ease-out),
      filter var(--duration-base) var(--ease-out),
      opacity var(--duration-base) var(--ease-out);
  }

  .home-nav:hover .home-link {
    filter: blur(2px);
    opacity: 0.3;
  }

  .home-nav:hover .home-link:hover {
    filter: blur(0);
    opacity: 1;
    color: var(--color-text);
  }
</style>
