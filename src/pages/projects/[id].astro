---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const dateStr = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<PageLayout title={`${project.data.title} — Finn Stäblein`}>
  <article class="project-detail">
    <a href="/projects" class="back-link">&larr; Projects</a>

    <header class="project-header">
      <div class="meta-block">
        <div class="meta-row">
          <span class="meta-label mono">Date</span>
          <time>{dateStr}</time>
        </div>
        {project.data.stack.length > 0 && (
          <div class="meta-row">
            <span class="meta-label mono">Stack</span>
            <span>{project.data.stack.join(', ')}</span>
          </div>
        )}
        {project.data.repo && (
          <div class="meta-row">
            <span class="meta-label mono">Repo</span>
            <a href={project.data.repo} target="_blank" rel="noopener noreferrer" class="ext-link">{project.data.repo}</a>
          </div>
        )}
        {project.data.link && (
          <div class="meta-row">
            <span class="meta-label mono">Live</span>
            <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="ext-link">{project.data.link}</a>
          </div>
        )}
      </div>

      <h1>{project.data.title}</h1>
      <p class="project-desc">{project.data.description}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>

<style>
  .project-detail {
    max-width: var(--content-width);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .project-header {
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .meta-block {
    border: 1px solid var(--color-border);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: var(--space-4);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-bg);
  }

  .meta-row:last-child {
    border-bottom: none;
  }

  .meta-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }

  .ext-link {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ext-link:hover {
    color: var(--color-accent);
  }

  .project-header h1 {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }

  .project-desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
</style>
