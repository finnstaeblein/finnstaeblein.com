---
import PageLayout from '../../layouts/PageLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const notes = allNotes.sort((a, b) =>
  ((b.data.quality ?? 0) + (b.data.significance ?? 0)) - ((a.data.quality ?? 0) + (a.data.significance ?? 0))
);

const categories = ['book', 'movie', 'article', 'video', 'paper'] as const;
---

<PageLayout title="Index — Finn Stäblein" description="Notes on books, movies, and articles.">
  <div class="index-page">
    <div class="index-header">
      <h1>Index</h1>
    </div>

    <div class="index-controls">
      <div class="filter-buttons" role="group" aria-label="Filter by category">
        {categories.map(cat => (
          <button
            class="filter-btn"
            data-filter={cat}
          >
            {cat.charAt(0).toUpperCase() + cat.slice(1) + 's'}
          </button>
        ))}
        <a href="/thoughts" class="filter-btn thoughts-link">Thoughts</a>
      </div>

      <input
        type="search"
        class="search-input"
        placeholder="Search"
        aria-label="Search notes"
        id="notes-search"
      />
    </div>

    <div class="index-count">
      <span class="mono" id="notes-count">{notes.length} entries</span>
    </div>

    <div class="index-table">
      <div class="table-header">
        <span class="col-index mono">No.</span>
        <span class="col-title">Title</span>
        <span class="col-creator">Author</span>
        <span class="col-type mono">Type</span>
        <span class="col-score mono">Q</span>
        <span class="col-score mono">S</span>
      </div>

      <div id="notes-list">
        {notes.map((note, i) => (
          <NoteCard
            id={note.id}
            index={i + 1}
            title={note.data.title}
            category={note.data.category}
            quality={note.data.quality}
            significance={note.data.significance}
            creator={note.data.creator}
          />
        ))}
      </div>
    </div>

    <p class="no-results" id="no-results" style="display: none;">
      No entries found.
    </p>
  </div>
</PageLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const searchInput = document.getElementById('notes-search') as HTMLInputElement | null;
    const notesList = document.getElementById('notes-list');
    const countEl = document.getElementById('notes-count');
    const noResults = document.getElementById('no-results');

    if (!notesList || !searchInput) return;

    const cards = notesList.querySelectorAll<HTMLAnchorElement>('.note-row');

    // Read filter from URL hash, default to 'book'
    let activeCategory: string | null = location.hash.slice(1) || 'book';

    function setActiveButton() {
      filterButtons.forEach(b => {
        if (b.dataset.filter === activeCategory) b.classList.add('active');
        else b.classList.remove('active');
      });
    }

    function filterNotes() {
      const query = searchInput!.value.toLowerCase().trim();
      let visible = 0;

      cards.forEach(card => {
        const category = card.dataset.category || '';
        const title = card.dataset.title || '';
        const creator = card.dataset.creator || '';

        const matchesCategory = !activeCategory || category === activeCategory;
        const matchesSearch = !query ||
          title.includes(query) ||
          creator.includes(query);

        const show = matchesCategory && matchesSearch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (countEl) countEl.textContent = `${visible} entr${visible !== 1 ? 'ies' : 'y'}`;
      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    }

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter || '';
        if (activeCategory === filter) {
          activeCategory = null;
          history.replaceState(null, '', location.pathname);
          btn.classList.remove('active');
        } else {
          activeCategory = filter;
          history.replaceState(null, '', `#${filter}`);
          setActiveButton();
        }
        filterNotes();
      });
    });

    // Restore filter on back navigation
    window.addEventListener('hashchange', () => {
      activeCategory = location.hash.slice(1) || 'book';
      setActiveButton();
      filterNotes();
    });

    // Apply initial filter
    setActiveButton();
    filterNotes();

    let debounceTimer: ReturnType<typeof setTimeout>;
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterNotes, 150);
    });
  });
</script>

<style>
  .index-page {
    max-width: var(--max-width);
  }

  .index-header h1 {
    font-size: var(--text-2xl);
    font-weight: 400;
    margin-bottom: var(--space-6);
  }

  .index-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }

  .filter-buttons {
    display: flex;
    gap: var(--space-4);
  }

  .filter-btn {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding: 0;
    transition: color var(--duration-fast) ease;
  }

  .filter-btn:hover {
    color: var(--color-text);
  }

  .filter-btn.active {
    color: var(--color-accent);
  }

  .thoughts-link {
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-4);
  }

  .search-input {
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    width: 200px;
  }

  .search-input::placeholder {
    color: var(--color-text-secondary);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .index-count {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .index-table {
    border-top: 1px solid var(--color-border);
  }

  .table-header {
    display: grid;
    grid-template-columns: 48px 1fr 1fr 80px 40px 40px;
    gap: var(--space-4);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }

  .table-header .col-score {
    text-align: right;
  }

  .no-results {
    text-align: center;
    color: var(--color-text-secondary);
    padding: var(--space-16) 0;
    font-size: var(--text-sm);
  }

  @media (max-width: 640px) {
    .table-header {
      grid-template-columns: 36px 1fr 48px 28px 28px;
    }
    .table-header .col-creator {
      display: none;
    }
  }
</style>
