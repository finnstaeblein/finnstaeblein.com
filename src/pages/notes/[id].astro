---
import PageLayout from '../../layouts/PageLayout.astro';
import Divider from '../../components/Divider.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(note => ({
    params: { id: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

const dateStr = note.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout title={`${note.data.title} — Finn Stäblein`}>
  <article class="note-detail">
    <a href="/notes" class="back-link">&larr; Index</a>

    <header class="note-header">
      <div class="meta-block">
        <div class="meta-row">
          <span class="meta-label mono">Type</span>
          <span>{note.data.category}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label mono">Author</span>
          <span>{note.data.creator}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label mono">Date</span>
          <time datetime={note.data.date.toISOString()}>{dateStr}</time>
        </div>
        {note.data.quality != null && (
          <div class="meta-row">
            <span class="meta-label mono">Quality</span>
            <span>{note.data.quality}/10</span>
          </div>
        )}
        {note.data.significance != null && (
          <div class="meta-row">
            <span class="meta-label mono">Significance</span>
            <span>{note.data.significance}/10</span>
          </div>
        )}
        {note.data.tags.length > 0 && (
          <div class="meta-row">
            <span class="meta-label mono">Tags</span>
            <span>{note.data.tags.join(', ')}</span>
          </div>
        )}
        {note.data.url && (
          <div class="meta-row">
            <span class="meta-label mono">Source</span>
            <a href={note.data.url} target="_blank" rel="noopener noreferrer" class="source-link">{note.data.url}</a>
          </div>
        )}
      </div>

      <h1>{note.data.title}</h1>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</PageLayout>

<style>
  .note-detail {
    max-width: var(--content-width);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) ease;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .note-header {
    margin-top: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .meta-block {
    border: 1px solid var(--color-border);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .meta-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-4);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-bg);
  }

  .meta-row:last-child {
    border-bottom: none;
  }

  .meta-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
    align-self: baseline;
  }

  .source-link {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .source-link:hover {
    color: var(--color-accent);
  }

  .note-header h1 {
    font-size: var(--text-2xl);
    font-weight: 400;
  }
</style>
