---
interface Props {
  id: string;
  index: number;
  title: string;
  category: string;
  quality?: number;
  significance?: number;
  creator: string;
}

const { id, index, title, category, quality, significance, creator } = Astro.props;
const indexStr = String(index).padStart(3, '0');
---

<a
  href={`/notes/${id}`}
  class="note-row"
  data-category={category}
  data-title={title.toLowerCase()}
  data-creator={creator.toLowerCase()}
>
  <span class="col-index mono">{indexStr}</span>
  <span class="col-title">{title}</span>
  <span class="col-creator">{creator}</span>
  <span class="col-type mono">{category}</span>
  <span class="col-score mono">{quality != null ? quality : '—'}</span>
  <span class="col-score mono">{significance != null ? significance : '—'}</span>
</a>

<style>
  .note-row {
    display: grid;
    grid-template-columns: 48px 1fr 1fr 80px 40px 40px;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
    transition: color var(--duration-fast) ease;
  }

  .note-row:hover {
    color: var(--color-accent);
  }

  .col-index {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .note-row:hover .col-index {
    color: var(--color-accent);
  }

  .col-title {
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .col-creator {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .note-row:hover .col-creator {
    color: var(--color-accent);
  }

  .col-type {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .col-score {
    font-size: var(--text-xs);
    text-align: right;
    color: var(--color-text-secondary);
  }

  .note-row:hover .col-score {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .note-row {
      grid-template-columns: 36px 1fr 48px 28px 28px;
    }
    .col-creator {
      display: none;
    }
  }
</style>
