---
interface Props {
  id: string;
  index: number;
  title: string;
  description: string;
  date: Date;
  stack?: string[];
}

const { id, index, title, description, date, stack = [] } = Astro.props;
const indexStr = String(index).padStart(2, '0');
const year = date.getFullYear();
---

<a href={`/projects/${id}`} class="project-row">
  <span class="col-index mono">{indexStr}</span>
  <span class="col-title">{title}</span>
  <span class="col-desc">{description}</span>
  <span class="col-year mono">{year}</span>
</a>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 36px 200px 1fr 60px;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
    transition: color var(--duration-fast) ease;
  }

  .project-row:hover {
    color: var(--color-accent);
  }

  .col-index {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .project-row:hover .col-index {
    color: var(--color-accent);
  }

  .col-title {
    font-weight: 400;
  }

  .col-desc {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-row:hover .col-desc {
    color: var(--color-accent);
  }

  .col-year {
    font-size: var(--text-xs);
    text-align: right;
    color: var(--color-text-secondary);
  }

  .project-row:hover .col-year {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .project-row {
      grid-template-columns: 36px 1fr 48px;
    }
    .col-desc {
      display: none;
    }
  }
</style>
