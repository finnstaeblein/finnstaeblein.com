---
interface Props {
  id: string;
  index: number;
  title: string;
  summary: string;
  theme: string;
}

const { id, index, title, summary, theme } = Astro.props;
const indexStr = String(index).padStart(2, '0');

const themeLabels: Record<string, string> = {
  ai: 'AI',
  strategy: 'Strategy',
  gtm: 'GTM',
  epistemics: 'Epistemics',
};
---

<a
  href={`/lattice/${id}`}
  class="lattice-row note-row"
  data-theme={theme}
  data-title={title.toLowerCase()}
>
  <span class="col-index mono">{indexStr}</span>
  <span class="col-title">{title}</span>
  <span class="col-summary">{summary}</span>
  <span class="col-theme mono">{themeLabels[theme] ?? theme}</span>
</a>

<style>
  .lattice-row {
    display: grid;
    grid-template-columns: 36px 220px 1fr 90px;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
    transition: color var(--duration-fast) ease;
  }

  .lattice-row:hover {
    color: var(--color-accent);
  }

  .col-index {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .lattice-row:hover .col-index {
    color: var(--color-accent);
  }

  .col-title {
    font-weight: 400;
  }

  .col-summary {
    color: var(--color-text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .lattice-row:hover .col-summary {
    color: var(--color-accent);
  }

  .col-theme {
    font-size: var(--text-xs);
    text-align: right;
    color: var(--color-text-secondary);
  }

  .lattice-row:hover .col-theme {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .lattice-row {
      grid-template-columns: 36px 1fr 72px;
    }
    .col-summary {
      display: none;
    }
  }
</style>
